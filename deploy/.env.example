# =============================================================================
# any-auto-register — VPS deployment configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# Then start the stack:
#   docker compose up -d --build
# =============================================================================

# --- Domains (DNS A records must point at your VPS IP) ---
# Primary instance domain
AAR_DOMAIN=register.example.com

# Optional: Pro instance domain (remove if not using)
AARPRO_DOMAIN=pro.example.com

# Optional: Bank statement generator domain (remove if not using)
BANK_DOMAIN=bank.example.com

# Let's Encrypt / ACME email (for certificate expiry notifications)
ACME_EMAIL=you@example.com

# --- Build contexts (relative to deploy/) ---
# Default: main repo is parent directory (..)
AAR_CONTEXT=..
# AARPRO_CONTEXT=../any-auto-register-pro
# BANK_CONTEXT=../bank-statement-generator

# --- CamouFox browser version (leave as-is unless you need a specific version) ---
# CAMOUFOX_VERSION=135.0.1
# CAMOUFOX_RELEASE=beta.24

# --- Data persistence directories (created automatically on first run) ---
AAR_DATA=./data/any-auto-register
AAR_EXT=./_ext_targets/any-auto-register
# AARPRO_DATA=./data/any-auto-register-pro
# AARPRO_EXT=./_ext_targets/any-auto-register-pro
# BANK_DATA=./data/bank-statement-generator

# --- Solver ---
# APP_ENABLE_SOLVER=1
# SOLVER_BROWSER_TYPE=camoufox
# PLAYWRIGHT_HEADLESS=

# --- Port bindings (only needed if you expose services directly) ---
# CLIPROXYAPI_PORT_BIND=8317
# GROK2API_PORT_BIND=8011

# =============================================================================
# Authelia identity provider (single source of truth for auth)
# =============================================================================
# Generate fresh random secrets, e.g.:
#   openssl rand -hex 32  (jwt + session)
#   openssl rand -hex 16  (storage encryption key)
AUTHELIA_JWT_SECRET=replace-me-with-64-hex-chars
AUTHELIA_SESSION_SECRET=replace-me-with-64-hex-chars
AUTHELIA_STORAGE_SECRET=replace-me-with-32-hex-chars

# Comma-separated list of allowed CORS origins for the FastAPI app.
# Defaults to https://<AAR_DOMAIN>,https://auth.<AAR_DOMAIN>
APP_CORS_ORIGINS=https://register.example.com,https://auth.register.example.com

# --- Optional SMTP for Authelia email (password reset / 2FA backup) ---
# Leave blank to keep the filesystem notifier (notices written to
# authelia/notification.txt and read by the admin). To enable email delivery,
# fill these AND uncomment the `smtp:` block in authelia/configuration.yml.
AUTHELIA_NOTIFIER_SMTP_HOST=
AUTHELIA_NOTIFIER_SMTP_PORT=587
AUTHELIA_NOTIFIER_SMTP_USERNAME=
AUTHELIA_NOTIFIER_SMTP_PASSWORD=
AUTHELIA_NOTIFIER_SMTP_SENDER=
