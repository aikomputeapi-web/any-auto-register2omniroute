# Caddy reverse proxy for the multi-app stack.
# Authelia provides the login page; Caddy uses forward_auth to check
# every request before proxying to the backend.

{
	email admin@nowrouter.info
}

# Authelia portal (login page)
auth.nowrouter.info {
	encode zstd gzip
	reverse_proxy authelia:9091
}

# Main site - protected by Authelia
nowrouter.info {
	encode zstd gzip

	forward_auth authelia:9091 {
		uri /api/authz/forward-auth
		copy_headers Remote-User Remote-Groups Remote-Email
	}

	reverse_proxy any-auto-register:8000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		flush_interval -1
	}
}
