[Unit]
Description=Auto-deploy Webhook Listener
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/any-auto-register
Environment=WEBHOOK_PORT=9000
Environment=WEBHOOK_SECRET=your-secret-here-change-me
Environment=DEPLOY_DIR=/opt/any-auto-register
ExecStart=/usr/bin/python3 /opt/any-auto-register/scripts/webhook_listener.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
