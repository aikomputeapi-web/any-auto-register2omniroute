{
  "name": "any-auto-register",
  "version": "1.0.0",
  "description": "Any Auto Register - Multi-platform account automatic registration management tool",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build:backend": "bash build-backend.sh",
